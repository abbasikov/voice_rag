# Frontend Configuration

# Backend API Base URL
# For local development, use the default (http://localhost:8000)
# For production/deployment, set this to your deployed backend URL
# Examples:
#   VITE_API_URL=https://yourusername-voice-rag-backend.hf.space
#   VITE_API_URL=https://your-backend-api.example.com
# If not set, defaults to http://localhost:8000
VITE_API_URL=http://localhost:8000
